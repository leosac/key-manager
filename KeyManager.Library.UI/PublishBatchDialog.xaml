<UserControl x:Class="Leosac.KeyManager.Library.UI.PublishBatchDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.UI"
             xmlns:properties="clr-namespace:Leosac.KeyManager.Library.UI.Properties"
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.UI.Domain"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:PublishBatchDialogViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             MinWidth="600" MinHeight="400">

    <UserControl.Resources>
        <SolidColorBrush x:Key="SuccessBrush" Color="LimeGreen"/>
        <SolidColorBrush x:Key="InfoBrush" Color="White"/>
        <SolidColorBrush x:Key="WarningBrush" Color="Orange"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="Red"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="LogoBrush" Color="Gray"/>
        <SolidColorBrush x:Key="TextBrush" Color="DarkGray"/>
        <SolidColorBrush x:Key="KeyNameBrush" Color="DodgerBlue"/>
        <local:ChangePadding x:Key="SubtractPaddingConverter" Subtract="20"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="BatchProgressStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource KeyNameBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LogTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Success">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="59*"/>
            <ColumnDefinition Width="136*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Label}"
                   FontSize="18"
                   Margin="0,0,0,10" Grid.ColumnSpan="2"/>

        <Border Grid.Row="1"
                Padding="10"
                CornerRadius="6"
                Background="{DynamicResource MaterialDesignCardBackground}"
                Margin="0,0,0,10" MinHeight="250" MinWidth="700" Grid.ColumnSpan="2">
            <GroupBox Header="{x:Static properties:Resources.ExecutionLogs}">
                <TreeView x:Name="LogTree"
                          ItemsSource="{Binding Logs}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=GroupBox}, Converter={StaticResource SubtractPaddingConverter}}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type domain:LogEntry}" ItemsSource="{Binding Nodes}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayText}" Padding="2" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Info">
                                                    <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding Nodes}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="0,1,0,1"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </GroupBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,10" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.BatchProgress}" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="{Binding ThroughputText}" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="2" Height="20" Minimum="0" Maximum="{Binding BatchProgressMaximum}" Value="{Binding BatchProgressValue, Mode=OneWay}" Style="{StaticResource BatchProgressStyle}"/>
            <TextBlock Grid.Row="3" Text="{Binding BatchProgressText}" HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource LogoBrush}"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10" Visibility="{Binding HasStarted, Converter={StaticResource BoolToVisibilityConverter}}" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.KeyStoreProgress}" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="1" Height="20" Minimum="0" Maximum="{Binding KeyStoreProgressMaximum}" Value="{Binding KeyStoreProgressValue, Mode=OneWay}" Style="{StaticResource BatchProgressStyle}"/>
            <TextBlock Grid.Row="2" Text="{Binding KeyStoreProgressText}" HorizontalAlignment="Right" FontSize="12" Foreground="Gray"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock FontSize="12">
                    <Run Text="{x:Static properties:Resources.KeyLogo}" Foreground="{StaticResource LogoBrush}"/>
                    <Run Text="{x:Static properties:Resources.TextProcessing}" Foreground="{StaticResource TextBrush}"/>
                    <Run Text="{Binding CurrentKeyName, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource KeyNameBrush}"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="{StaticResource LogoBrush}" FontStyle="Italic" Margin="5,0,0,0" Text="..." Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="5" Orientation="Vertical">
            <materialDesign:Snackbar x:Name="SnackbarControl"
                                     MessageQueue="{Binding SnackbarQueue}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,5"
                                     IsHitTestVisible="True"
                                     Panel.ZIndex="100"/>
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton IsChecked="{Binding LoggingVerbosity, Mode=TwoWay}" IsEnabled="{Binding CanToggleLogging}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                    <TextBlock Text="{x:Static properties:Resources.VerboseLogging}" Padding="3"/>
                </StackPanel>
            </Grid>

            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <ToggleButton IsChecked="{Binding BatchOptions.Notifications}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                    <TextBlock Text="{x:Static properties:Resources.EnableNotifications}" Padding="3"/>
                </StackPanel>
                <Button Grid.Column="2" Content="{x:Static properties:Resources.ButtonNext}" Width="100" Margin="0,0,0,0" Command="{Binding NextCommand}" Visibility="{Binding ShowNextButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <ToggleButton IsChecked="{Binding BatchOptions.RetryOnFailure}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                    <TextBlock Text="{x:Static properties:Resources.RetryOnFailureBatch}" Padding="3"/>
                </StackPanel>
                <Button Grid.Column="2" Content="{x:Static properties:Resources.ButtonRetry}" Width="100" Margin="100,0,0,0" Command="{Binding RetryCommand}" Visibility="{Binding ShowRetryButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Grid.Column="3" Content="{x:Static properties:Resources.ButtonSkip}" Width="100" Margin="10,0,0,0" Command="{Binding SkipCommand}" Visibility="{Binding ShowSkipButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <ToggleButton IsChecked="{Binding BatchOptions.TimeoutWait}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                <TextBlock Text="{x:Static properties:Resources.TimeoutWaitBatch}" Padding="3"/>
                <TextBox Width="50" Margin="5,0,0,0" Text="{Binding TimeoutWaitSecondsText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding BatchOptions.TimeoutWait}"/>
                <TextBlock Text="{x:Static properties:Resources.TimeSecond}" Margin="2,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                <Button Content="{x:Static properties:Resources.ButtonStart}" Width="100" Margin="5,0" Command="{Binding StartBatchCommand}" Visibility="{Binding CanStart, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="{x:Static properties:Resources.ButtonPause}" Width="100" Margin="5,0" Command="{Binding PauseCommand}" Visibility="{Binding CanPause, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="{x:Static properties:Resources.ButtonResume}" Width="100" Margin="5,0" Command="{Binding ResumeCommand}" Visibility="{Binding CanResume, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="{x:Static properties:Resources.ButtonCancel}" Width="100" Margin="5,0" Command="{Binding CancelBatchCommand}" IsEnabled="{Binding CanCancel}"/>
                <Button Content="{x:Static properties:Resources.ButtonClose}" Width="100" Margin="5,0" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>