<UserControl x:Class="Leosac.KeyManager.Library.UI.PublishBatchDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.UI"
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.UI.Domain"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:PublishBatchDialogViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             MinWidth="600" MinHeight="400">

    <UserControl.Resources>
        <local:ChangePadding x:Key="SubtractPaddingConverter" Subtract="20"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="BatchProgressStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="DodgerBlue"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Foreground" Value="LimeGreen"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Foreground" Value="Tomato"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LogTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Success">
                    <Setter Property="Foreground" Value="LimeGreen"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Foreground" Value="Orange"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Foreground" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="59*"/>
            <ColumnDefinition Width="136*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="{Binding Label}"
                   FontSize="18"
                   Margin="0,0,0,10" Grid.ColumnSpan="2"/>
        <Border Grid.Row="1"
                Padding="10"
                CornerRadius="6"
                Background="{DynamicResource MaterialDesignCardBackground}"
                Margin="0,0,0,10" MinHeight="250" MinWidth="700" Grid.ColumnSpan="2">
            <GroupBox Header="Execution Logs">
                <TreeView x:Name="LogTree"
                          ItemsSource="{Binding Logs}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=GroupBox}, Converter={StaticResource SubtractPaddingConverter}}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type domain:LogEntry}" ItemsSource="{Binding Nodes}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayText}" Padding="2" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Success">
                                                    <Setter Property="Foreground" Value="LimeGreen"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Info">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding Nodes}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="0,1,0,1"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </GroupBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,10" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Batch Progress" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="{Binding ThroughputText}" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="2" Height="20" Minimum="0" Maximum="{Binding BatchProgressMaximum}" Value="{Binding BatchProgressValue, Mode=OneWay}" Style="{StaticResource BatchProgressStyle}"/>
            <TextBlock Grid.Row="3" Text="{Binding BatchProgressText}" HorizontalAlignment="Right" FontSize="12" Foreground="Gray"/>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,10" Visibility="{Binding HasStarted, Converter={StaticResource BoolToVisibilityConverter}}" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Current KeyStore Progress" Margin="0,0,0,5"/>
            <ProgressBar Grid.Row="1" Height="20" Minimum="0" Maximum="{Binding KeyStoreProgressMaximum}" Value="{Binding KeyStoreProgressValue, Mode=OneWay}" Style="{StaticResource BatchProgressStyle}"/>
            <TextBlock Grid.Row="2" Text="{Binding KeyStoreProgressText}" HorizontalAlignment="Right" FontSize="12" Foreground="Gray"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock FontSize="12">
                    <Run Text="🔑 " Foreground="Gray"/>
                    <Run Text="Processing : " Foreground="DarkGray"/>
                    <Run Text="{Binding CurrentKeyName, Mode=OneWay}" FontWeight="Bold" Foreground="DodgerBlue"/>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="Gray" FontStyle="Italic" Margin="5,0,0,0" Text="..." Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <ToggleButton IsChecked="{Binding LoggingVerbosity, Mode=TwoWay}"
                              IsEnabled="{Binding CanToggleLogging}"
                              Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                <TextBlock Text="Verbose Logging" Padding="3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <ToggleButton IsChecked="{Binding BatchOptions.Notifications}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                <TextBlock Text="Enable Notifications" Padding="3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <ToggleButton IsChecked="{Binding BatchOptions.RetryOnFailure}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                <TextBlock Text="Retry On Failure" Padding="3"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <ToggleButton IsChecked="{Binding BatchOptions.TimeoutWait}" Style="{StaticResource MaterialDesignSwitchLightToggleButton}" />
                <TextBlock Text="Timeout Wait" Padding="3"/>
                <TextBox Width="50" Margin="5,0,0,0" Text="{Binding BatchOptions.TimeoutWaitSeconds, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding BatchOptions.TimeoutWait}"/>
                <TextBlock Text="seconds" Margin="2,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Start" Width="100" Margin="0,0,10,0" Command="{Binding StartBatchCommand}" Visibility="{Binding CanStart, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Pause" Width="100" Margin="0,0,10,0" Command="{Binding PauseCommand}" Visibility="{Binding CanPause, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Resume" Width="100" Margin="0,0,10,0" Command="{Binding ResumeCommand}" Visibility="{Binding CanResume, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Cancel" Width="100" Margin="0,0,10,0" Command="{Binding CancelBatchCommand}" IsEnabled="{Binding CanCancel}"/>
                <Button Content="Close" Width="100" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>