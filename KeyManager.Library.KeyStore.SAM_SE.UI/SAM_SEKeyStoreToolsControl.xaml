<UserControl x:Class="Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.SAM_SEKeyStoreToolsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Domain"
             xmlns:libui="clr-namespace:Leosac.KeyManager.Library.UI;assembly=KeyManager.Library.UI"
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:properties="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Properties"
             xmlns:wpfappctrls="clr-namespace:Leosac.WpfApp.Controls;assembly=WpfApp"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:SAM_SEKeyStoreToolsControlViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Vertical">
        <materialDesign:Card Margin="5">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Expander Grid.Row="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Header="{x:Static properties:Resources.ToolsVersion}">
                    <materialDesign:Card Margin="5">
                        <StackPanel Orientation="Vertical" Margin="50,5,5,5">
                            <TextBlock Text="{Binding VersionSAM_SE}"/>
                            <TextBlock Text="{Binding VersionUT}"/>
                            <TextBlock Text="{Binding VersionUGL}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Expander>
                <Expander Grid.Row="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" 
                          IsExpanded="{Binding DefaultExpanderExpanded}" 
                          Header="{x:Static properties:Resources.ToolsUpdateDefault}">
                    <materialDesign:Card Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="10" FontSize="14"
                                Text="{x:Static properties:Resources.ToolsWarningDefaultFile}" Foreground="OrangeRed" TextWrapping="WrapWithOverflow"/>
                            <Grid Grid.Row="1" Grid.Column="0" Margin="10,0,0,10" MaxWidth="700" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.ToolsSummary}" FontWeight="Bold" Foreground="Green"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf1}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding Configuration1}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding Configuration2Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf2}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding Configuration2}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding Configuration3Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf3}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding Configuration3}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding Configuration4Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf4}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding Configuration4}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfClassic}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationClassic}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfUltra}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationUltra}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfPlus}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationPlus}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf125k}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding Configuration125k}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,10" MaxWidth="700" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.ToolsSummary}" FontWeight="Bold" Foreground="Green"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf1}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardened1}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding ConfigurationHardened2Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf2}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardened2}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding ConfigurationHardened3Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf3}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardened3}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="28,0,0,0" Visibility="{Binding ConfigurationHardened4Displayed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf4}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardened4}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfClassic}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardenedClassic}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfUltra}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardenedUltra}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConfPlus}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardenedPlus}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="28,0,0,0">
                                    <TextBlock Text="{x:Static properties:Resources.ToolsConfFileConf125k}" FontWeight="DemiBold"/>
                                    <TextBlock Text="{Binding ConfigurationHardened125k}"/>
                                </StackPanel>
                            </Grid>
                            <WrapPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="24,8,24,16"
                                   TextBlock.Foreground="{DynamicResource MaterialDesignBody}">
                                <Button Content="{x:Static properties:Resources.ToolsSecurEvoDefault}"
                                    Command="{Binding SAM_SEDefaultConfigFileCommand}"
                                    Margin="5" />
                            </WrapPanel>
                            <WrapPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="24,8,24,16"
                                  TextBlock.Foreground="{DynamicResource MaterialDesignBody}">
                                <Button Content="{x:Static properties:Resources.ToolsSecurEvoHardened}"
                                   Command="{Binding SAM_SEHardenedConfigFileCommand}"
                                   Margin="5" />
                            </WrapPanel>
                        </Grid>
                    </materialDesign:Card>
                </Expander>
                <Expander Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" 
                          IsExpanded="{Binding LockedLevelExpanded}"
                          Header="{x:Static properties:Resources.ToolsLockUnlock}">
                    <materialDesign:Card Margin="5">
                        <WrapPanel HorizontalAlignment="Center" Orientation="Vertical" TextBlock.Foreground="{DynamicResource MaterialDesignBody}" Margin="24,8,24,16">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition MinHeight="50"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{x:Static properties:Resources.ToolsLockKeyShort}" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Static properties:Resources.ToolsLockDefaultShort}" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Static properties:Resources.ToolsLockAdvancedShort}" Grid.Row="0" Grid.Column="4" HorizontalAlignment="Center"/>
                                <Slider Value="{Binding SAM_SEKeyStore.Properties.Locked, Mode=TwoWay}"
                                Grid.Row="1" Grid.ColumnSpan="5" 
                                MinWidth="600" Margin="30,10,30,0"
                                IsSnapToTickEnabled="True"
                                Minimum="{Binding LockedMin}"
                                Maximum="{Binding LockedMax}"
                                SmallChange="1" TickFrequency="1" TickPlacement="TopLeft">
                                </Slider>
                                <TextBlock Text="{Binding SAM_SEKeyStore.Properties.LockedLevelString}" Grid.Row="2" Grid.ColumnSpan="5" Margin="0,10,0,5"/>
                            </Grid>
                            <WrapPanel HorizontalAlignment="Center" Margin="0,5,0,0">
                                <Button Content="{x:Static properties:Resources.Update}"
                                    Command="{Binding SAM_SELockCommand}"
                                    Margin="5" />
                            </WrapPanel>
                        </WrapPanel>
                    </materialDesign:Card>
                </Expander>
            </Grid>
        </materialDesign:Card>
    </StackPanel>
</UserControl>
