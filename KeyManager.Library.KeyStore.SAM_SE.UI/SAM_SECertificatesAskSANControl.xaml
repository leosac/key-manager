<UserControl x:Class="Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.SAM_SECertificatesAskSANControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Domain"
             xmlns:libui="clr-namespace:Leosac.KeyManager.Library.UI;assembly=KeyManager.Library.UI"
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:properties="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Properties"
             xmlns:wpfappctrls="clr-namespace:Leosac.WpfApp.Controls;assembly=WpfApp"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:SAM_SEKeyStoreCertificatesControlViewModel}"
             d:DesignHeight="400" d:DesignWidth="600" PreviewKeyDown="Key_Pressed">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="250"/>
            <ColumnDefinition MinWidth="100"/>
            <ColumnDefinition MinWidth="250"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0" HorizontalAlignment="Center" Text="{x:Static properties:Resources.ConfigurationSAN}"/>
        <materialDesign:Card Grid.Row="1" Grid.RowSpan="4" Grid.Column="0">
            <StackPanel Margin="15" Orientation="Vertical">
                <TextBlock Text="Type :"/>
                <ComboBox ItemsSource="{Binding SANType}"
                          SelectedItem="{Binding SANTypeSelected}">
                </ComboBox>
                <TextBlock Margin="0,20,0,0" Text="Valeur :"/>
                <TextBox Text="{Binding SANValue}"/>
            </StackPanel>
        </materialDesign:Card>
        <materialDesign:Card Grid.Row="1" Grid.RowSpan="4" Grid.Column="3">
            <ListBox ItemsSource="{Binding SAN}"
                     SelectedItem="{Binding SANSelected}">
            </ListBox>
        </materialDesign:Card>
        <Button Grid.Row="2" Grid.Column="1" Content="{x:Static properties:Resources.Add}" Margin="20,10,20,0" Click="Btn_Add"/>
        <Button Grid.Row="3" Grid.Column="1" Content="{x:Static properties:Resources.Delete}" Margin="20,10,20,0" Click="Btn_Delete"/>
        <Button Grid.Row="5" Grid.Column="0" Content="{x:Static properties:Resources.Cancel}" Margin="20,10,20,0" Click="Btn_Cancel" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
        <Button Grid.Row="5" Grid.Column="2" Content="{x:Static properties:Resources.Valid}" Margin="20,10,20,0" Click="Btn_Valid" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
    </Grid>
</UserControl>
