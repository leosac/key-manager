<UserControl x:Class="Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.SAM_SEKeyStoreCertificatesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Domain"
             xmlns:libui="clr-namespace:Leosac.KeyManager.Library.UI;assembly=KeyManager.Library.UI"
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:properties="clr-namespace:Leosac.KeyManager.Library.KeyStore.SAM_SE.UI.Properties"
             xmlns:wpfappctrls="clr-namespace:Leosac.WpfApp.Controls;assembly=WpfApp"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:SAM_SEKeyStoreCertificatesControlViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Load" Unloaded="UserControl_Unload">
    <UserControl.Resources>
        <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" TrueValue="Visible" FalseValue="Collapsed" />
        <materialDesign:BooleanToVisibilityConverter x:Key="BooleanToVisibilityHiddenConverter" TrueValue="Visible" FalseValue="Hidden" />
        <materialDesign:BooleanToVisibilityConverter x:Key="ReverseBooleanToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />

        <DataTemplate x:Key="RCATemplate">
            <materialDesign:Card Margin="5" MinWidth="200" Height="200">
                <materialDesign:Card.ToolTip>
                    <TextBlock Text="{Binding ToolTip}"/>
                </materialDesign:Card.ToolTip>
                <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CommonName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10" Name="DropRCA"
                                AllowDrop="True" DragOver="CertificatesDragEnter" Drop="CertificatesDragDrop">
                            <materialDesign:PackIcon Width="100" Height="100" HorizontalAlignment="Center" Margin="0,15,0,0"
                                Kind="FileCertificate" Visibility="{Binding ValidCertificate, Converter={StaticResource BooleanToVisibilityConverter}}" Foreground="LimeGreen"/>
                            <materialDesign:PackIcon Width="100" Height="100" HorizontalAlignment="Center" Margin="0,15,0,0"
                                Kind="FileUpload" Visibility="{Binding ValidCertificate, Converter={StaticResource ReverseBooleanToVisibilityConverter}}"/>
                            <Rectangle Name="BrowseRCAIcon" Margin="5,5,5,0" Height="120" Width="200" Fill="Transparent" MouseDown="BtnBrowse_Click"
                                Stroke="{DynamicResource MaterialDesignBody}" StrokeDashArray="10" RadiusX="10" RadiusY="10"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center"
                                Click="BtnBrowse_Click" Name="BrowseRCAButton">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Browse}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="FileSearch" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                            <Button HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center" Click="BtnDownload_Click" Name="DownloadRCA"
                                IsEnabled="{Binding Real, Mode=TwoWay}">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Download}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="Download" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                            <Button HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center" Click="BtnDelete_Click" Name="DeleteRCA"
                                IsEnabled="{Binding Real, Mode=TwoWay}">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Delete}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </DataTemplate>

        <DataTemplate x:Key="CAIntTemplate">
            <materialDesign:Card Margin="5" MinWidth="150" Height="200">
                <materialDesign:Card.ToolTip>
                    <TextBlock Text="{Binding ToolTip}"/>
                </materialDesign:Card.ToolTip>
                <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                        Text="{Binding CommonName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Grid HorizontalAlignment="Center">
                        <materialDesign:PackIcon Width="100" Height="100" Margin="0,15,0,0"
                            Kind="FileCertificate" Foreground="LimeGreen" HorizontalAlignment="Center"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button HorizontalAlignment="Center" Margin="5,20,5,0" VerticalAlignment="Center" Click="BtnDownload_Click" Name="DownloadCAInt"
                            IsEnabled="{Binding Real, Mode=TwoWay}">
                            <Button.ToolTip>
                                <ToolTip Placement="Bottom">
                                    <TextBlock Text="{x:Static properties:Resources.Download}"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20" HorizontalAlignment="Center"/>
                        </Button>
                        <Button HorizontalAlignment="Center" Margin="5,20,5,0" VerticalAlignment="Center" Click="BtnDelete_Click" Name="DeleteCAInt"
                            IsEnabled="{Binding Real, Mode=TwoWay}">
                            <Button.ToolTip>
                                <ToolTip Placement="Bottom">
                                    <TextBlock Text="{x:Static properties:Resources.Delete}"/>
                                </ToolTip>
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </DataTemplate>
        
        <DataTemplate x:Key="CertificatesTemplate">
            <materialDesign:Card Margin="5" MinWidth="250" Height="250" UniformCornerRadius="10">
                <materialDesign:Card.ToolTip>
                    <TextBlock Text="{Binding ToolTip}"/>
                </materialDesign:Card.ToolTip>
                <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10"
                            FontSize="20" FontWeight="Bold" Text="{Binding TypeName, UpdateSourceTrigger=PropertyChanged}"/>

                        <Separator Grid.Row="0" Margin="0,20,0,0"/>

                        <Grid Grid.Row="1" Name="DropCA" 
                            AllowDrop="True" DragOver="CertificatesDragEnter" Drop="CertificatesDragDrop">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0"
                                Text="{Binding CommonName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="0" Margin="0,20,0,0" Foreground="LimeGreen"
                                Kind="FileCertificate" Width="100" Height="100" HorizontalAlignment="Center"
                                Visibility="{Binding ValidCertificate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="0" Margin="0,20,0,20" Kind="FileUpload" Width="80" Height="80"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ValidCertificate, Converter={StaticResource ReverseBooleanToVisibilityConverter}}"/>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="1" Margin="0,40,15,0" Foreground="LimeGreen"
                                Kind="Key" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Top"
                                Visibility="{Binding ValidKey, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="1" Margin="0,0,10,30" Kind="Key" Width="64" Height="64"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ValidKey, Converter={StaticResource ReverseBooleanToVisibilityConverter}}"/>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="1" Margin="0,60,5,30" Kind="ArrowTopBold" Width="40" Height="40"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ValidKey, Converter={StaticResource ReverseBooleanToVisibilityConverter}}"/>
                            <Rectangle Name="BrowseCAIcon" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5,5,5,0" Height="130" Width="240" Fill="Transparent"
                                Stroke="{DynamicResource MaterialDesignBody}" StrokeDashArray="10" RadiusX="10" RadiusY="10" MouseDown="BtnBrowse_Click"/>
                        </Grid>

                        <Separator Margin="0,0,0,30" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"/>
                        
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0,5,0,0" Content="CSR" Click="BtnCSR_Click" Name="CsrCA">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.CSR}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button Grid.Column="1" Margin="5,5,0,0" Click="BtnBrowse_Click" Name="BrowseCAButton">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Browse}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="FileSearch" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="2" Margin="5,5,0,0" Click="BtnDownload_Click" Name="DownloadCA"
                                IsEnabled="{Binding ValidCertificate, Mode=TwoWay}">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Download}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="Download" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Grid.Column="3" Margin="5,5,0,0" Click="BtnDelete_Click" Name="DeleteCA"
                                IsEnabled="{Binding Real, Mode=TwoWay}">
                                <Button.ToolTip>
                                    <ToolTip Placement="Bottom">
                                        <TextBlock Text="{x:Static properties:Resources.Delete}"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>

                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </DataTemplate>

    </UserControl.Resources>
    <StackPanel Orientation="Vertical">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Expander Grid.Row="0" IsExpanded="True" Header="{x:Static properties:Resources.QuickCommissioning}">
                <materialDesign:Card Margin="30,5,30,5">
                    <Grid Margin="30,20,30,20">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Margin="0,0,0,10" Text="{x:Static properties:Resources.CUSetting}" FontSize="18"/>
                        <Separator Grid.Row="0" Grid.ColumnSpan="4" Margin="0,12,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="10,0,0,0" Text="{x:Static properties:Resources.CUName}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding CUName}" Width="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="10,0,0,0" Text="{x:Static properties:Resources.CUId}" VerticalAlignment="Center"/>
                        <wpfappctrls:NumericUpDownControl Grid.Row="2" Grid.Column="1" CurrentValue="{Binding CUId, Mode=TwoWay}"
                            MinValue="1" MaxValue="9990" Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="10,0,10,0" Text="{x:Static properties:Resources.RadiusIdentity}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding RadiusIdentity}" Width="433" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,10" Text="{x:Static properties:Resources.NetworkSetting}" FontSize="18"/>
                        <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,35,4,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="10,20,0,10" Text="{x:Static properties:Resources.ACSSetting}" FontSize="18"/>
                        <Separator Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="10,35,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="10,0,0,0" Text="{x:Static properties:Resources.CUIp}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CUIp, Mode=TwoWay}" Width="100" HorizontalAlignment="Left" 
                             VerticalAlignment="Center" PreviewTextInput="IPValidationTextBox"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Margin="20,0,10,0" Text="{x:Static properties:Resources.ACSIp}"
                             VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding ACSIp, Mode=TwoWay}" Width="100" HorizontalAlignment="Left"
                             VerticalAlignment="Center" PreviewTextInput="IPValidationTextBox"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="10,0,0,0" Text="{x:Static properties:Resources.CUMask}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CUMask, Mode=TwoWay}" Width="100" HorizontalAlignment="Left" 
                             VerticalAlignment="Center" PreviewTextInput="IPValidationTextBox"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Margin="20,0,0,0" Text="{x:Static properties:Resources.FDLPort}" VerticalAlignment="Center"/>
                        <wpfappctrls:NumericUpDownControl Grid.Row="6" Grid.Column="3" CurrentValue="{Binding FDLPort, Mode=TwoWay}"
                            MinValue="1" MaxValue="65535" Width="80"  HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="10,0,0,0" Text="{x:Static properties:Resources.CUGateway}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CUGateway, Mode=TwoWay}" Width="100" HorizontalAlignment="Left" 
                             VerticalAlignment="Center" PreviewTextInput="IPValidationTextBox"/>
                        <TextBlock Grid.Row="7" Grid.Column="2" Margin="20,0,0,0" Text="{x:Static properties:Resources.UpdatePort}" VerticalAlignment="Center"/>
                        <wpfappctrls:NumericUpDownControl Grid.Row="7" Grid.Column="3" CurrentValue="{Binding UpdatePort, Mode=TwoWay}"
                            MinValue="1" MaxValue="65535" Width="80"  HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                
                    </Grid>
                </materialDesign:Card>
            </Expander>
            <Expander Grid.Row="1" IsExpanded="False" Header="{x:Static properties:Resources.RCA}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ListView Margin="0,0,0,14" MouseDoubleClick="OnCardDoubleClick"
                        ItemsSource="{Binding RCA}" ItemTemplate="{StaticResource RCATemplate}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </StackPanel>
            </Expander>
            <Expander Grid.Row="2" IsExpanded="False" Header="{x:Static properties:Resources.ICA}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ListView Margin="0,0,0,14" MouseDoubleClick="OnCardDoubleClick"
                        ItemsSource="{Binding CAInt}" ItemTemplate="{StaticResource CAIntTemplate}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                    <materialDesign:Card Margin="5,0,5,15" MinWidth="150" Height="200">
                        <materialDesign:Card.ToolTip>
                            <TextBlock Text="{x:Static properties:Resources.ToolTipDepositCert}"/>
                        </materialDesign:Card.ToolTip>
                        <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{x:Static properties:Resources.DragDrop}"/>
                                </StackPanel>

                                <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10" Name="DropCAInt"
                                    AllowDrop="True" DragOver="CertificatesDragEnter" Drop="CertificatesDragDrop">
                                    <materialDesign:PackIcon Width="100" Height="100" HorizontalAlignment="Center" Margin="0,15,0,0" Kind="FileUpload"/>
                                    <Rectangle Name="BrowseCAIntIcon" Margin="5,5,5,0" Height="120" Width="140" Fill="Transparent" MouseDown="BtnBrowse_Click"
                                        Stroke="{DynamicResource MaterialDesignBody}" StrokeDashArray="10" RadiusX="10" RadiusY="10"/>
                                </Grid>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center"
                                        Click="BtnBrowse_Click" Name="BrowseCAIntButton">
                                        <Button.ToolTip>
                                            <ToolTip Placement="Bottom">
                                                <TextBlock Text="{x:Static properties:Resources.Browse}"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <materialDesign:PackIcon Kind="FileSearch" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center" Click="BtnDelete_Click" Name="DeleteCAIntAll"
                                        IsEnabled="{Binding NotEmptyCAInt, Mode=TwoWay}">
                                        <Button.ToolTip>
                                            <ToolTip Placement="Bottom">
                                                <TextBlock Text="{x:Static properties:Resources.DeleteList}"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Expander>
            <Expander Grid.Row="3" IsExpanded="False" Header="{x:Static properties:Resources.Certificates}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ListView Margin="0,0,0,14" MouseDoubleClick="OnCardDoubleClick"
                        ItemsSource="{Binding Certificates}" ItemTemplate="{StaticResource CertificatesTemplate}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>
                </StackPanel>
            </Expander>
            <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                <Button Content="{x:Static properties:Resources.UpdateCertificates}" Click="BtnUpdate_Click">
                    <Button.ToolTip>
                        <ToolTip Placement="Bottom">
                            <TextBlock Text="{x:Static properties:Resources.UpdateCertificatesToolTip}"/>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
