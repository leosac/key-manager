<UserControl x:Class="KeyManager.Library.KeyStore.KeePass.UI.KeePassKeyStorePropertiesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:Leosac.KeyManager.Library.KeyStore.KeePass.UI.Domain"
             xmlns:kslibdomain="clr-namespace:Leosac.KeyManager.Library.UI.Domain;assembly=KeyManager.Library.UI"
             xmlns:kslibproperties="clr-namespace:Leosac.KeyManager.Library.UI.Properties;assembly=KeyManager.Library.UI"
             xmlns:lib="clr-namespace:Leosac.KeyManager.Library.KeyStore.KeePass;assembly=KeyManager.Library.KeyStore.KeePass"
             xmlns:local="clr-namespace:Leosac.KeyManager.Library.KeyStore.KeePass.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:properties="clr-namespace:Leosac.KeyManager.Library.KeyStore.KeePass.UI.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance domain:KeePassKeyStorePropertiesControlViewModel}"
             Width="560"
             MinHeight="380"
             materialDesign:ColorZoneAssist.Mode="PrimaryMid"
             x:ClassModifier="public">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <domain:ComparisonConverter x:Key="ComparisonConverter"/>
        <SolidColorBrush x:Key="NonExhaustiveTrueBrush" Color="Red"/>
        <SolidColorBrush x:Key="NonExhaustiveFalseBrush" Color="Green"/>
        <SolidColorBrush x:Key="HighlightedBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="DisabledBrush" Color="#FFBDBDBD"/>

        <Style x:Key="ProfileItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                            Background="Transparent"
                            CornerRadius="4"
                            Margin="1">
                                <TextBlock Text="{Binding DisplayName}"
                                   Padding="4"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsNonExhaustive}" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource NonExhaustiveTrueBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsNonExhaustive}" Value="False">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource NonExhaustiveFalseBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </DataTrigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HighlightedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
    </UserControl.Resources>

    <Grid Margin="16,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="{x:Static properties:Resources.Title}"
                   FontSize="15"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="1" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{x:Static properties:Resources.File}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="0,0,12,0"/>

            <TextBox Grid.Column="1"
                     Text="{Binding FileProperties.DBPath, Mode=OneWay}"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     VerticalAlignment="Center" Margin="10,0,0,0"/>

            <Button Grid.Column="2"
                    Command="{Binding BrowseFileCommand}"
                    Style="{StaticResource MaterialDesignIconButton}">
                <materialDesign:PackIcon Kind="FolderOpen"/>
            </Button>
            <materialDesign:PopupBox Grid.Column="3"
                                     Width="32"
                                     Height="32"
                                     VerticalAlignment="Center"
                                     PlacementMode="BottomAndAlignRightEdges">
                <materialDesign:PopupBox.ToggleContent>
                    <materialDesign:PackIcon Kind="DotsVertical"
                                             Width="18"
                                             Height="18"/>
                </materialDesign:PopupBox.ToggleContent>
                <StackPanel MinWidth="140">
                    <Button Content="{x:Static properties:Resources.Create}"
                            Command="{Binding CreateKeyStoreCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>
            </materialDesign:PopupBox>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,4,0,8">
            <TextBlock Text="{x:Static properties:Resources.CredentialMode}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                    <RadioButton Content="{x:Static properties:Resources.PasswordOnly}" IsChecked="{Binding FileProperties.SelectedCredentialMode, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static lib:CredentialMode.PasswordOnly}}" GroupName="CredentialMode" />
                    <RadioButton Content="{x:Static properties:Resources.KeyFileOnly}" IsChecked="{Binding FileProperties.SelectedCredentialMode, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static lib:CredentialMode.KeyFileOnly}}" GroupName="CredentialMode" Margin="12,0"/>
                    <RadioButton Content="{x:Static properties:Resources.PasswordPlusKey}" IsChecked="{Binding FileProperties.SelectedCredentialMode, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static lib:CredentialMode.PasswordAndKey}}" GroupName="CredentialMode"/>
                </StackPanel>
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding Properties.StoreSecret, Mode=TwoWay}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              ToolTip="{x:Static properties:Resources.StoreSecret}"
                              Width="35" Margin="2">
                    <materialDesign:PackIcon Kind="ContentSave" RenderTransformOrigin=".5,.5">
                        <materialDesign:PackIcon.RenderTransform>
                            <RotateTransform Angle="45"/>
                        </materialDesign:PackIcon.RenderTransform>
                    </materialDesign:PackIcon>
                    <materialDesign:ToggleButtonAssist.OnContent>
                        <materialDesign:PackIcon Kind="ContentSave"/>
                    </materialDesign:ToggleButtonAssist.OnContent>
                </ToggleButton>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Static properties:Resources.Password}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="0,0,12,0"/>
                <PasswordBox Grid.ColumnSpan="2"
                             Margin="121,0,20,0"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             materialDesign:TextFieldAssist.CharacterCounterVisibility="Visible"
                             materialDesign:PasswordBoxAssist.Password="{Binding Properties.Secret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox"
                               BasedOn="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FileProperties.SelectedCredentialMode,
                                    Converter={StaticResource ComparisonConverter},
                                    ConverterParameter={x:Static lib:CredentialMode.KeyFileOnly}}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
            </Grid>
            <Grid Visibility="{Binding FileProperties.KeyFileIsRequired, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="63*"/>
                    <ColumnDefinition Width="9*"/>
                    <ColumnDefinition Width="137*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Static properties:Resources.MasterKey}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="0,0,12,0"/>
                <TextBox Text="{Binding Properties.KeyPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="1"
                         IsReadOnly="True"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         VerticalAlignment="Center" Margin="32,0,0,0" Grid.ColumnSpan="3"/>
                <Button Grid.Column="4"
                        Command="{Binding BrowseKeyFileCommand}"
                        Style="{StaticResource MaterialDesignIconButton}">
                    <materialDesign:PackIcon Kind="FolderKey"/>
                </Button>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Content="{x:Static properties:Resources.ProfileChecker}"
                    Command="{Binding TestConnectionCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="8,0"/>
            <Button Content="{x:Static properties:Resources.Clear}"
                    Command="{Binding ClearAllCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="8,0"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,4,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{x:Static properties:Resources.Profile}"
               VerticalAlignment="Center"
               FontSize="12"
               Margin="0,0,10,0"/>

            <ComboBox
                Grid.Column="1"
                ItemsSource="{Binding Profiles}"
                DisplayMemberPath="DisplayName"
                SelectedItem="{Binding SelectedProfile}"
                ItemContainerStyle="{StaticResource ProfileItemStyle}"
                Background="{Binding SelectedProfileBackground, Mode=OneWay}"
                MinHeight="30"/>

            <StackPanel Grid.Column="2"
                Orientation="Vertical"
                VerticalAlignment="Center"
                Margin="8,0,0,0">

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,4">
                    <ToggleButton
                          IsChecked="{Binding IsExhaustive, Mode=TwoWay}"
                          Style="{StaticResource MaterialDesignSwitchLightToggleButton}"
                          Width="40"
                          Height="24"
                          Margin="0,0,4,0"
                          ToolTip="{x:Static properties:Resources.ExhaustiveInfo}"/>
                    <TextBlock Text="{x:Static properties:Resources.Exhaustive}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,0">
                    <ToggleButton
                          IsChecked="{Binding Properties.Silent}"
                          Style="{StaticResource MaterialDesignSwitchLightToggleButton}"
                          Width="40"
                          Height="24"
                          Margin="0,0,4,0"
                          ToolTip="{x:Static properties:Resources.SilentInfo}"/>
                    <TextBlock Text="{x:Static properties:Resources.Silent}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="6"
                BorderBrush="LightGray"
                BorderThickness="1"
                Padding="6"
                CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusType}" Value="Success">
                            <Setter Property="Background" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                            <Setter Property="Background" Value="Orange"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusType}" Value="Error">
                            <Setter Property="Background" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding Status}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ProgressBar Visibility="{Binding ShowProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Width="70" Height="4"
                     DockPanel.Dock="Right"
                     IsIndeterminate="True"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>