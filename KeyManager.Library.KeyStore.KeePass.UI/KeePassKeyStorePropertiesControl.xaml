<UserControl x:Class="KeyManager.Library.KeyStore.KeePass.UI.KeePassKeyStorePropertiesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:KeyManager.Library.KeyStore.KeePass.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             x:ClassModifier="public">

    <UserControl.Resources>
        <Style x:Key="KeePassInput" TargetType="TextBox">
            <Setter Property="Width" Value="420"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="StatusBar" TargetType="Border">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryAction" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <FontFamily x:Key="Icons">pack://application:,,,/FontAwesome.WPF;component/Fonts/#FontAwesome</FontFamily>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
               Text="KeePass Database Connection"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,24"
               Foreground="#1F2937"/>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                 Text="🗄️ KeePass File (.kdbx)"
                 VerticalAlignment="Center"
                 FontSize="15"
                 FontWeight="SemiBold"
                 Margin="0,0,16,0"/>

            <TextBox x:Name="TxtFilePath" Style="{StaticResource KeePassInput}" Grid.Column="1"
               Text="{Binding DefaultPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Path to your .kdbx file"/>

            <Button x:Name="BtnBrowse" Width="44" Height="44" Grid.Column="2"
                Content="📁" Click="BtnBrowse_Click"
                ToolTip="Browse for KeePass database"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                 Text="🔐 Master Password"
                 VerticalAlignment="Center"
                 FontSize="15"
                 FontWeight="SemiBold"
                 Margin="0,0,16,0"/>

            <PasswordBox x:Name="Password" Width="420" Height="44" Grid.Column="1"
                   VerticalContentAlignment="Center"
                   Padding="12,8"
                   ToolTip="Master password for kdbx file"/>

            <Button x:Name="BtnKeyFile" Width="44" Height="44" Grid.Column="2" Margin="0,0,0,4"
              Content="🔑" Click="BtnKeyFile_Click"
              ToolTip="Add key file (optional)"/>
        </Grid>

        <Grid Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnTest" Style="{StaticResource PrimaryAction}"
                Content="🔗 Test Connection" Click="BtnTest_Click"/>
                <Button x:Name="BtnClear" Margin="12,0,0,0" Height="44" Padding="20,0"
                Content="🗑️ Clear" Click="BtnClear_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource StatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtStatus" Grid.Column="0"
                   Text="Ready to connect • No file selected"
                   FontSize="14"
                   VerticalAlignment="Center"
                   Foreground="#6B7280"/>

                <TextBlock x:Name="FileInfo" Grid.Column="1"
                   Text=""
                   FontSize="12"
                   VerticalAlignment="Center"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Right"/>

                <ProgressBar x:Name="ProgressBar" Grid.Column="2"
                     Width="120" Height="6" Margin="16,0,0,0"
                     Visibility="Collapsed"
                     VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>